# jinro-community 환경변수. 실제 값은 .env.local 에 넣으세요 (git 무시됨).
# 이 프로젝트는 자체 Firebase 프로젝트를 씁니다 (moon2 컨벤션: 앱마다 독립 DB).

# --- Firebase 클라이언트 (브라우저 노출 가능, Phase 2 Auth용) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (서버 전용 — 절대 클라이언트 노출 금지) ---
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"의 JSON에서 옮겨오세요.
# PRIVATE_KEY 는 따옴표로 감싸고 줄바꿈을 \n 으로 둡니다.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Claude API (서버 전용 — 수업앱 빌더의 AI 블록용) ---
# 없으면 AI 기능만 비활성(제출은 정상 저장). platform.claude.com 에서 발급.
ANTHROPIC_API_KEY=

# --- Firebase Storage 버킷 (원본 PDF 저장) ---
# 콘솔 > Storage 활성화 후 버킷명. 보통 NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET 과 동일.
# 안 넣으면 NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET 을 사용.
FIREBASE_STORAGE_BUCKET=

# --- 정보 수신 시크릿 (서버 전용) ---
# kakao-daily가 생성 정보를 POST /api/info 로 밀어넣을 때 쓰는 공유 시크릿.
# kakao-daily 쪽에도 같은 값을 넣고, 요청 헤더 x-ingest-secret 로 보냅니다.
INFO_INGEST_SECRET=
